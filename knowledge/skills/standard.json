{
  "id": "standard",
  "name": "标准产品评估",
  "description": "按页面×功能点拆解，按角色（产品/设计、前端开发、后端开发、测试）分别估算工时，适合大多数 Web/App 项目",
  "version": "1.0",
  "roles": ["产品/设计", "前端开发", "后端开发", "测试"],
  "decomposition": {
    "strategy": "page_feature",
    "max_pages": 8,
    "max_features_per_page": 10,
    "focus": "从产品经理视角，按页面维度拆解功能点，对比系统已有能力区分新增/调整"
  },
  "estimation": {
    "strategy": "role_based",
    "base_rates": {
      "新增页面-简单": {"产品/设计": 0.25, "前端开发": 0.5,  "后端开发": 0.3, "测试": 0.3},
      "新增页面-中等": {"产品/设计": 0.5,  "前端开发": 1.0,  "后端开发": 0.8, "测试": 0.5},
      "新增页面-复杂": {"产品/设计": 1.0,  "前端开发": 1.5,  "后端开发": 1.5, "测试": 1.0},
      "调整页面-简单": {"产品/设计": 0.1,  "前端开发": 0.2,  "后端开发": 0.1, "测试": 0.2},
      "调整页面-中等": {"产品/设计": 0.2,  "前端开发": 0.4,  "后端开发": 0.3, "测试": 0.3},
      "调整页面-复杂": {"产品/设计": 0.5,  "前端开发": 0.8,  "后端开发": 0.8, "测试": 0.5}
    },
    "complexity_bonuses": {
      "审批流":   {"加成天数": 0.3, "说明": "多级或条件分支审批，每个角色均加"},
      "外部接口": {"加成天数": 0.3, "说明": "对接第三方 API，后端为主"},
      "批量操作": {"加成天数": 0.2, "说明": "批量导入/导出/操作"},
      "复杂计算": {"加成天数": 0.3, "说明": "复杂业务规则或算法"},
      "多角色":   {"加成天数": 0.2, "说明": "同一功能支持 2 个以上不同角色视图"},
      "实时数据": {"加成天数": 0.2, "说明": "WebSocket 或高频轮询"}
    }
  },
  "_说明": [
    "可直接编辑此文件定制评估体系，保存后调用 /skills/reload 生效",
    "base_rates 的 key 格式：「新增/调整页面-简单/中等/复杂」",
    "复杂度由 LLM 根据功能点数量和复杂度自动判断",
    "历史案例请放到 knowledge/examples/standard/ 目录下，格式参考 README"
  ]
}
