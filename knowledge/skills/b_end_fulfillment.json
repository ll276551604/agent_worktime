{
  "id": "b_end_fulfillment",
  "name": "B端履约中台评估",
  "description": "专为B端履约中台定制化项目设计：支持标品复用、功能改造、完全新建三种类型，四端（产品/前端/后端/测试）分角色工时评估，基于57条历史案例知识库",
  "version": "1.0",
  "roles": ["产品", "前端", "后端", "测试"],
  "decomposition": {
    "strategy": "page_feature",
    "max_pages": 10,
    "max_features_per_page": 8,
    "focus": "B端履约中台产品经理视角，按功能点拆解（CRUD算1个、独立页面算1个），区分开发类型：完全新增/适应性改造/新增/业务联调",
    "dev_types": ["完全新增", "适应性改造", "新增", "业务联调"]
  },
  "estimation": {
    "strategy": "role_based",
    "test_formula": "backend * 0.35",
    "base_rates": {
      "产品-S": {"产品": 0.5},
      "产品-M": {"产品": 1.0},
      "产品-L": {"产品": 1.5},
      "产品-XL": {"产品": 3.0},
      "产品-XXL": {"产品": 4.5},
      "前端-0": {"前端": 0.0},
      "前端-S": {"前端": 0.5},
      "前端-M": {"前端": 1.0},
      "前端-L": {"前端": 1.5},
      "前端-XL": {"前端": 2.5},
      "前端-XXL": {"前端": 4.5},
      "后端-S": {"后端": 1.0},
      "后端-M": {"后端": 2.5},
      "后端-L": {"后端": 5.0},
      "后端-XL": {"后端": 8.0},
      "后端-XXL": {"后端": 13.0}
    },
    "tier_rules": {
      "产品": {
        "S": "单接口说明/单配置项追加/字段扩展说明",
        "M": "标准增删改查配置表（字段10-15）/接口+单页面",
        "L": "2-3个页面/含导出+导入/含数据同步逻辑",
        "XL": "含业务规则执行+通知/跨系统联动/完整业务流程",
        "XXL": "全新子系统（5+页面）/可视化规则配置器/复杂报表2个+"
      },
      "前端": {
        "0": "纯后端接口，无页面",
        "S": "纯展示只读页/已有页面追加字段或按钮",
        "M": "标准CRUD单页（字段10-15，含弹窗表单）",
        "L": "复杂查询列表（查询条件10+）/2个标准页面",
        "XL": "3-4个页面含联动/含图表报表",
        "XXL": "5+页面/可视化规则配置器/含移动端独立体系"
      },
      "后端": {
        "S": "单接口字段改造/简单查询接口（字段<10）",
        "M": "1-2个标准CRUD接口组（含表设计+权限+日志）",
        "L": "3-5个接口+业务逻辑/含数据同步链路",
        "XL": "完整功能模块（配置+执行+通知）/含规则引擎",
        "XXL": "跨系统全链路/含状态机+异步+重试+多系统联调"
      }
    },
    "complexity_bonuses": {
      "产品加分": {
        "查询条件15+": 0.5,
        "含业务规则引擎": 0.75,
        "含审批流": 1.5,
        "含移动端/企业微信小程序": 1.0,
        "复杂报表（每个）": 1.5
      },
      "后端加分": {
        "跨系统对接（每个外部系统）": 2.5,
        "含异步处理/消息队列/定时任务": 1.5,
        "含业务规则匹配逻辑": 2.5,
        "含报表数据加工": 2.0,
        "含幂等/分布式一致性处理": 0.75,
        "含大批量导出10W+行": 1.0
      },
      "测试加分": {
        "跨系统集成测试（3+系统节点）": 1.0,
        "含回归测试（改造已有核心链路）": 0.75,
        "含性能测试（高并发/大批量）": 1.0
      }
    },
    "zero_worktime_patterns": [
      "复用现有功能/链路",
      "已有功能，无改造",
      "标品支持，不涉及定制",
      "与方案确认无改造"
    ],
    "report_templates": {
      "简单报表": {"产品": 1, "前端": 1, "后端": 3, "测试": 1},
      "复杂报表": {"产品": 2, "前端": 2, "后端": 5, "测试": 2}
    }
  }
}
