# API Key 配置文件
# 复制此文件为 .env 并填写你的 API 密钥

# 阿里云 DashScope API Key（推荐）
DASHSCOPE_API_KEY=sk-f448e9a456f849b984fac86018b92e48

# Google Gemini API Key
GEMINI_API_KEY=AIzaSyApe10peWhXvGV_JkD6LAypw15XoqUfO8c

# ── 本地知识库路径（填写你本地文件夹的绝对路径，留空则使用项目内默认目录）────────────
# 业务知识库目录：放 Markdown 格式的业务领域文档（流程说明、业务规则、术语表等）
# 默认：项目内 knowledge/business/
BUSINESS_KB_DIR=

# 代码知识库目录：放手写的 Markdown 接口文档、数据模型说明、模块概述等
# 默认：项目内 knowledge/code_knowledge/
CODE_KB_DIR=

# Java 源代码目录：系统自动扫描 REST Controller + Entity 类，用于判断接口/模型是否已存在
# 留空则跳过 Java 自动扫描
JAVA_SOURCE_DIR=
